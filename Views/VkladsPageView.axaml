<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BankDeposits.ViewModels"
             x:Class="BankDeposits.Views.VkladsPageView"
             x:DataType="vm:VkladsPageViewModel">

	<Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
		<!-- Панель поиска -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
			<TextBox Text="{Binding SearchText}"
					 Watermark="Поиск по названию..."
					 Width="300" />
			<Button Content="Поиск"
					Command="{Binding SearchCommand}" />
		</StackPanel>

		<!-- Панель импорта/экспорта -->
		<StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
			<TextBlock Text="Импорт:" VerticalAlignment="Center" FontWeight="Bold" />
			<Button Content="CSV" Command="{Binding ImportCSVCommand}" />
			<Button Content="Excel" Command="{Binding ImportExcelCommand}" />
			<Button Content="JSON" Command="{Binding ImportJSONCommand}" />
			<Button Content="XML" Command="{Binding ImportXMLCommand}" />
			<TextBlock Text="Экспорт:" VerticalAlignment="Center" FontWeight="Bold" Margin="20,0,0,0" />
			<Button Content="CSV" Command="{Binding ExportCSVCommand}" />
			<Button Content="Excel" Command="{Binding ExportExcelCommand}" />
			<Button Content="JSON" Command="{Binding ExportJSONCommand}" />
			<Button Content="XML" Command="{Binding ExportXMLCommand}" />
		</StackPanel>

		<!-- Панель добавления/удаления -->
		<StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
			<Button Content="Добавить"
					Command="{Binding AddCommand}"
					Background="#4CAF50"
					Foreground="White"/>
			<Button Content="Удалить"
					Command="{Binding DeleteCommand}"
					IsEnabled="{Binding SelectedVklad, Converter={x:Static ObjectConverters.IsNotNull}}"
					Background="#F44336"
					Foreground="White"/>
		</StackPanel>

		<!-- Шапка таблицы -->
		<Border Grid.Row="3"
				BorderThickness="1"
				BorderBrush="#CCCCCC"
				Background="#F5F5F5">
			<Grid ColumnDefinitions="80,*,120,120"
				  Height="30">
				<TextBlock Grid.Column="0"
						   Text="Код"
						   FontWeight="Bold"
						   VerticalAlignment="Center"
						   Margin="10,0"/>
				<TextBlock Grid.Column="1"
						   Text="Наименование"
						   FontWeight="Bold"
						   VerticalAlignment="Center"
						   Margin="10,0"/>
				<TextBlock Grid.Column="2"
						   Text="Срок (мес.)"
						   FontWeight="Bold"
						   VerticalAlignment="Center"
						   Margin="10,0"/>
				<TextBlock Grid.Column="3"
						   Text="Ставка (%)"
						   FontWeight="Bold"
						   VerticalAlignment="Center"
						   Margin="10,0"/>
			</Grid>
		</Border>

		<!-- Список вкладов -->
		<ListBox Grid.Row="4"
				 ItemsSource="{Binding Vklads}"
				 SelectedItem="{Binding SelectedVklad}"
				 BorderThickness="0">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border BorderBrush="#EEEEEE"
							BorderThickness="0,0,0,1"
							Padding="10">
						<Grid ColumnDefinitions="80,*,120,120">
							<TextBlock Grid.Column="0"
									   Text="{Binding Id}"
									   FontWeight="Bold"/>
							<TextBlock Grid.Column="1"
									   Text="{Binding Name}"/>
							<TextBlock Grid.Column="2"
									   Text="{Binding TermMonths}"/>
							<TextBlock Grid.Column="3"
									   Text="{Binding Rate, StringFormat={}{0:F2}%}"/>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</UserControl>